---
import CtaButton from "../components/CtaButton.astro";
import CoffeeIllustration from "../components/CoffeeIllustration.astro";
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
---

<Layout
  title="Página no encontrada - Webeo"
  description="La página que buscas no existe o se ha movido."
>
  <main class="bg-[#fbfaf7] px-5 py-16 text-[#171b17] md:px-8 md:py-20">
    <section class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <div class="flex flex-col items-center" data-animate>
        <Logo markClass="h-10 w-10" textClass="text-lg font-black text-[#173a2a]" />
        <p class="mt-10 text-sm font-black uppercase tracking-[.18em] text-[#b77d1f]">Error 404</p>
        <h1 class="mt-4 max-w-2xl text-5xl font-black leading-[.96] tracking-tight md:text-6xl">
          Esta página se ha ido a tomar un café.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-8 text-[#596359]">
          No hemos encontrado la URL que buscas. Puede que se haya movido, que el enlace esté roto o que todavía no exista.
        </p>
        <div class="mt-8 flex w-full max-w-md flex-col justify-center gap-3 sm:flex-row">
          <CtaButton href="/" label="Volver al inicio" />
          <CtaButton href="/contacto" label="Hablar con Webeo" variant="secondary" />
        </div>
      </div>

      <div class="mt-12 w-full max-w-xl" data-animate>
        <div class="rounded-lg border border-[#e6e0d5] bg-white p-4 shadow-[0_18px_50px_rgba(45,39,27,.08)]">
          <div class="mb-5 flex gap-2">
            <span class="h-3 w-3 rounded-full bg-[#e36a4a]"></span>
            <span class="h-3 w-3 rounded-full bg-[#f0b94d]"></span>
            <span class="h-3 w-3 rounded-full bg-[#7b8f78]"></span>
          </div>
          <div class="rounded-md bg-[#173a2a] p-6 text-left text-white md:p-8">
            <div class="flex items-center justify-between">
              <span class="text-sm font-bold text-white/65">/ruta-perdida</span>
              <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-black">404</span>
            </div>
            <div class="mt-10 grid gap-4">
              <div class="h-4 w-3/4 rounded-full bg-white/70"></div>
              <div class="h-4 w-1/2 rounded-full bg-white/35"></div>
              <div class="mt-5 grid items-end gap-4 sm:grid-cols-[1fr_auto]">
                <div class="grid grid-cols-3 gap-3">
                  <span class="h-4 rounded bg-white/15"></span>
                  <span class="h-4 rounded bg-white/25"></span>
                  <span class="h-4 rounded bg-[#f0b94d]"></span>
                </div>
                <div class="hidden w-20 opacity-95 sm:block">
                  <CoffeeIllustration />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
