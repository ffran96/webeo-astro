---
import FinalCta from "../components/FinalCta.astro";
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
import MetricsStrip from "../components/MetricsStrip.astro";
import Portfolio from "../components/Portfolio.astro";
import Process from "../components/Process.astro";
import Results from "../components/Results.astro";
import Services from "../components/Services.astro";
import { metrics } from "../data/metrics";
import { projects } from "../data/portfolio";
import { processSteps } from "../data/process";
import { services } from "../data/services";
---

<Layout
  title="Webeo - Webs, SEO y campañas para captar más clientes"
  description="Agencia de marketing digital especializada en webs, aplicaciones web, SEO, SEM, analítica y automatizaciones para captar clientes online."
>
  <main id="inicio" class="min-h-screen bg-[#fbfaf7] text-[#171b17]">
    <Hero />
    <MetricsStrip metrics={metrics} />
    <Services services={services} />
    <Portfolio projects={projects} />
    <Process steps={processSteps} />
    <Results />
    <FinalCta />
  </main>
</Layout>
