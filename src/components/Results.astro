---
import CtaButton from "./CtaButton.astro";

interface Props {
  whatsappUrl: string;
}

const { whatsappUrl } = Astro.props;
---

<section id="resultados" class="scroll-mt-24 mx-auto grid max-w-7xl gap-10 px-5 py-20 md:px-8 md:py-28 lg:grid-cols-2 lg:items-center">
  <div data-animate>
    <p class="text-sm font-bold uppercase tracking-[.18em] text-[#b77d1f]">Resultados</p>
    <h2 class="mt-4 text-4xl font-black tracking-tight md:text-5xl">Bonita por fuera. Medible por dentro.</h2>
    <p class="mt-5 text-lg leading-8 text-[#596359]">
      Cada proyecto nace con objetivos concretos: contactos, reservas, presupuestos, ventas o visibilidad. Diseñamos la experiencia y dejamos la medición lista para saber qué funciona.
    </p>
    <CtaButton
      class="mt-8"
      href={whatsappUrl}
      label="Detectar oportunidades"
      target="_blank"
      rel="noreferrer"
    />
  </div>
  <div class="grid gap-4" data-stagger>
    <div class="rounded-lg border border-[#e6e0d5] bg-white p-6" data-stagger-item>
      <div class="flex items-center justify-between gap-4">
        <span class="font-bold text-[#596359]">Captación mensual</span>
        <span class="rounded-full bg-[#edf4ef] px-3 py-1 text-sm font-black text-[#173a2a]">+48%</span>
      </div>
      <div class="mt-7 flex h-40 items-end gap-3">
        <span class="h-[32%] flex-1 rounded-t bg-[#d8d3c8]"></span>
        <span class="h-[48%] flex-1 rounded-t bg-[#a9b5a5]"></span>
        <span class="h-[58%] flex-1 rounded-t bg-[#82947e]"></span>
        <span class="h-[73%] flex-1 rounded-t bg-[#f0b94d]"></span>
        <span class="h-[92%] flex-1 rounded-t bg-[#173a2a]"></span>
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-lg border border-[#e6e0d5] bg-white p-6" data-stagger-item>
        <span class="text-sm font-bold text-[#596359]">SEO técnico</span>
        <strong class="mt-3 block text-4xl font-black">Base sólida</strong>
      </div>
      <div class="rounded-lg border border-[#e6e0d5] bg-white p-6" data-stagger-item>
        <span class="text-sm font-bold text-[#596359]">Campañas</span>
        <strong class="mt-3 block text-4xl font-black">Sin humo</strong>
      </div>
    </div>
  </div>
</section>
