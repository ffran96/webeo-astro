---
import CtaButton from "./CtaButton.astro";
import Logo from "./Logo.astro";

interface Props {
  title: string;
  description: string;
  items: string[];
}

const { title, description, items } = Astro.props;
---

<section class="bg-[#fbfaf7] px-5 py-16 text-[#171b17] md:px-8">
  <div class="mx-auto max-w-3xl">
    <Logo markClass="h-8 w-8" textClass="text-sm font-black text-[#173a2a]" />
    <h1 class="mt-10 text-4xl font-black tracking-tight md:text-6xl">{title}</h1>
    <p class="mt-6 text-lg leading-8 text-[#596359]">{description}</p>
    <div class="mt-10 grid gap-4">
      {items.map((item) => (
        <p class="rounded-lg border border-[#e6e0d5] bg-white p-5 leading-7 text-[#4f594f]">{item}</p>
      ))}
    </div>
    <CtaButton class="mt-10" href="/" label="Volver a la web" size="sm" />
  </div>
</section>
