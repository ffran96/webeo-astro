---
import CtaButton from "./CtaButton.astro";
import Logo from "./Logo.astro";

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  navLinks: NavLink[];
}

const { navLinks } = Astro.props;
---

<header class="sticky top-0 z-30 border-b border-black/5 bg-[#fbfaf7]/90 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 md:px-8">
    <Logo />

    <div class="hidden items-center gap-8 text-sm font-medium text-[#4b544d] md:flex">
      {navLinks.map((link) => (
        <a data-scroll-link class="transition hover:text-[#171b17]" href={link.href}>{link.label}</a>
      ))}
    </div>

    <div class="hidden md:block">
      <CtaButton
        label="Pedir propuesta"
        size="sm"
        whatsappMessage="header"
      />
    </div>

    <div class="relative md:hidden">
      <button
        class="mobile-menu-trigger rounded-full border border-[#d8d3c8] bg-white px-4 py-3 text-sm font-black text-[#173a2a]"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        Menú
      </button>
      <div
        id="mobile-menu"
        class="mobile-menu-panel invisible absolute right-0 top-14 w-56 translate-y-2 rounded-lg border border-[#e6e0d5] bg-white p-2 opacity-0 shadow-[0_18px_45px_rgba(37,43,36,.14)] transition"
      >
        {navLinks.map((link) => (
          <a data-scroll-link class="block rounded-md px-4 py-3 text-sm font-bold text-[#273027] hover:bg-[#f4f0e8]" href={link.href}>{link.label}</a>
        ))}
        <CtaButton
          class="mt-1"
          label="Pedir propuesta"
          variant="menu"
          whatsappMessage="header"
        />
      </div>
    </div>
  </nav>
</header>
