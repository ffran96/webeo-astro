---
type Variant = "primary" | "secondary" | "inverse" | "menu";
type Size = "sm" | "md" | "lg";

interface Props {
  href: string;
  label: string;
  variant?: Variant;
  size?: Size;
  class?: string;
  target?: string;
  rel?: string;
  scroll?: boolean;
  animate?: boolean;
}

const {
  href,
  label,
  variant = "primary",
  size = "md",
  class: className = "",
  target,
  rel,
  scroll = false,
  animate = false,
} = Astro.props;

const variantClasses: Record<Variant, string> = {
  primary: "bg-[#173a2a] text-white shadow-[0_16px_34px_rgba(23,58,42,.18)] hover:bg-[#0f2c1f]",
  secondary: "border border-[#c9c4b7] bg-white text-[#173a2a] hover:border-[#173a2a]",
  inverse: "bg-white text-[#173a2a] hover:-translate-y-0.5",
  menu: "block rounded-md bg-[#173a2a] px-4 py-3 text-sm font-bold text-white",
};

const sizeClasses: Record<Size, string> = {
  sm: "px-5 py-3 text-sm",
  md: "px-7 py-4 text-base",
  lg: "px-7 py-4 text-base",
};

const baseClasses =
  variant === "menu"
    ? variantClasses.menu
    : `inline-flex w-fit items-center justify-center rounded-full text-center font-bold transition hover:-translate-y-0.5 ${variantClasses[variant]} ${sizeClasses[size]}`;
---

<a
  data-scroll-link={scroll ? true : undefined}
  data-animate={animate ? true : undefined}
  class={`${baseClasses} ${className}`}
  href={href}
  target={target}
  rel={rel}
>
  {label}
</a>
