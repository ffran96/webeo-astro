---
import CtaButton from "./CtaButton.astro";

interface Service {
  title: string;
  copy: string;
}

interface Props {
  services: Service[];
  whatsappUrl: string;
}

const { services, whatsappUrl } = Astro.props;
---

<section id="servicios" class="scroll-mt-24 mx-auto max-w-7xl px-5 py-20 md:px-8 md:py-28">
  <div class="grid gap-10 lg:grid-cols-[.72fr_1.28fr]">
    <div data-animate>
      <p class="text-sm font-bold uppercase tracking-[.18em] text-[#b77d1f]">Servicios</p>
      <h2 class="mt-4 text-4xl font-black tracking-tight md:text-5xl">Todo lo que necesita tu web para trabajar por ti.</h2>
      <p class="mt-5 text-lg leading-8 text-[#596359]">
        Unimos diseño, desarrollo y marketing para que no tengas piezas sueltas, sino un sistema digital con intención.
      </p>
      <CtaButton
        class="mt-8"
        href={whatsappUrl}
        label="Recibir una propuesta"
        target="_blank"
        rel="noreferrer"
      />
    </div>
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3" data-stagger>
      {services.map((service, index) => (
        <article class="rounded-lg border border-[#e6e0d5] bg-white p-6 shadow-[0_12px_38px_rgba(45,39,27,.06)]" data-stagger-item>
          <span class="text-sm font-black text-[#b77d1f]">{String(index + 1).padStart(2, "0")}</span>
          <h3 class="mt-5 text-2xl font-black tracking-tight">{service.title}</h3>
          <p class="mt-3 leading-7 text-[#5d665d]">{service.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>
