<button
  class="scroll-top-button invisible fixed bottom-5 right-5 z-40 inline-flex h-12 w-12 translate-y-3 cursor-pointer items-center justify-center rounded-full border border-[#d8d3c8] bg-[#173a2a] text-white opacity-0 shadow-[0_16px_34px_rgba(23,58,42,.22)] transition hover:-translate-y-0.5 hover:bg-[#0f2c1f] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#d9b25f] md:bottom-8 md:right-8"
  type="button"
  aria-label="Volver arriba"
  title="Volver arriba"
>
  <svg
    class="h-5 w-5"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.4"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="m18 15-6-6-6 6"></path>
  </svg>
</button>

<script>
  const button = document.querySelector<HTMLButtonElement>(".scroll-top-button");

  if (button) {
    const visibleClassNames = ["visible", "translate-y-0", "opacity-100"];
    const hiddenClassNames = ["invisible", "translate-y-3", "opacity-0"];

    const setButtonVisibility = () => {
      const shouldShow = window.scrollY > 520;

      button.classList.toggle("pointer-events-auto", shouldShow);
      button.classList.toggle("pointer-events-none", !shouldShow);

      visibleClassNames.forEach((className) => {
        button.classList.toggle(className, shouldShow);
      });

      hiddenClassNames.forEach((className) => {
        button.classList.toggle(className, !shouldShow);
      });
    };

    button.classList.add("pointer-events-none");
    setButtonVisibility();

    window.addEventListener("scroll", setButtonVisibility, { passive: true });
    button.addEventListener("click", () => {
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      window.scrollTo({ top: 0, behavior: prefersReducedMotion ? "auto" : "smooth" });
    });
  }
</script>
