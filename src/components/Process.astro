---
import CtaButton from "./CtaButton.astro";

interface Props {
  steps: string[];
  whatsappUrl: string;
}

const { steps, whatsappUrl } = Astro.props;
---

<section id="proceso" class="scroll-mt-24 bg-[#173a2a] text-white">
  <div class="mx-auto max-w-7xl px-5 py-20 md:px-8 md:py-28">
    <div class="max-w-3xl" data-animate>
      <p class="text-sm font-bold uppercase tracking-[.18em] text-[#f0b94d]">Proceso</p>
      <h2 class="mt-4 text-4xl font-black tracking-tight md:text-5xl">De una idea dispersa a un lanzamiento con dirección.</h2>
    </div>
    <div class="mt-12 grid gap-4 md:grid-cols-4" data-stagger>
      {steps.map((step, index) => (
        <div class="border-t border-white/18 pt-5" data-stagger-item>
          <span class="text-sm font-black text-[#f0b94d]">{String(index + 1).padStart(2, "0")}</span>
          <p class="mt-4 text-xl font-bold leading-7">{step}</p>
        </div>
      ))}
    </div>
    <CtaButton
      class="mt-12"
      href={whatsappUrl}
      label="Agendar diagnóstico gratuito"
      variant="inverse"
      target="_blank"
      rel="noreferrer"
      animate
    />
  </div>
</section>
