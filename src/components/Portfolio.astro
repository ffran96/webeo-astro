---
import CtaButton from "./CtaButton.astro";

interface Project {
  title: string;
  type: string;
  result: string;
  tone: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section id="portfolio" class="scroll-mt-24 bg-white">
  <div class="mx-auto max-w-7xl px-5 py-20 md:px-8 md:py-28">
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between" data-animate>
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[.18em] text-[#b77d1f]">Portfolio</p>
        <h2 class="mt-4 text-4xl font-black tracking-tight md:text-5xl">Trabajos visuales, claros y orientados a negocio.</h2>
      </div>
      <CtaButton
        label="Quiero algo así"
        whatsappMessage="portfolio"
      />
    </div>

    <div class="mt-12 grid gap-5 lg:grid-cols-3" data-stagger>
      {projects.map((project) => (
        <article class="group overflow-hidden rounded-lg border border-[#e6e0d5] bg-[#fbfaf7] shadow-[0_12px_38px_rgba(45,39,27,.06)]" data-stagger-item>
          <div class="p-4">
            <div class="rounded-md border border-black/5 bg-white p-3">
              <div class="mb-3 flex gap-1.5">
                <span class="h-2.5 w-2.5 rounded-full bg-[#e36a4a]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#d9b25f]"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-[#7b8f78]"></span>
              </div>
              <div class={`h-36 rounded-md ${project.tone} p-4 transition duration-300 group-hover:scale-[1.02]`}>
                <div class="h-4 w-20 rounded-full bg-white/80"></div>
                <div class="mt-8 h-3 w-32 rounded-full bg-white/55"></div>
                <div class="mt-3 h-3 w-24 rounded-full bg-white/35"></div>
                <div class="mt-8 grid grid-cols-3 gap-3">
                  <span class="h-10 rounded bg-white/20"></span>
                  <span class="h-10 rounded bg-white/35"></span>
                  <span class="h-10 rounded bg-white/55"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="border-t border-[#e6e0d5] p-6">
            <p class="text-sm font-bold text-[#b77d1f]">{project.type}</p>
            <h3 class="mt-2 text-2xl font-black tracking-tight">{project.title}</h3>
            <p class="mt-4 inline-flex rounded-full bg-white px-3 py-1 text-sm font-black text-[#173a2a]">{project.result}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
