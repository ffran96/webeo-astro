---
interface Props {
  label?: string;
  href?: string;
  markClass?: string;
  textClass?: string;
  class?: string;
  showText?: boolean;
}

const {
  label = "Webeo",
  href = "/",
  markClass = "h-9 w-9",
  textClass = "text-xl font-black tracking-tight",
  class: className = "",
  showText = true,
} = Astro.props;
---

<a href={href} class={`inline-flex items-center gap-3 ${className}`} aria-label={`${label} inicio`}>
  <svg class={markClass} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" role="img" aria-hidden="true">
    <rect width="128" height="128" rx="30" fill="#173a2a" />
    <path
      d="M28 36 L44 92 L64 50 L84 92 L100 36"
      fill="none"
      stroke="#fbfaf7"
      stroke-width="13"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle cx="104" cy="30" r="7" fill="#f0b94d" />
  </svg>
  {showText && <span class={textClass}>{label}</span>}
</a>
